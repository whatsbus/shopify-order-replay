# ---- Shopify app credentials (from Partner Dashboard) ----
SHOPIFY_API_KEY=your_api_key
SHOPIFY_API_SECRET=your_api_secret
# Read-only scopes ONLY. This app never writes to Shopify.
SHOPIFY_SCOPES=read_orders,read_products
# Public HTTPS URL where this app is hosted (no trailing slash)
SHOPIFY_APP_URL=https://your-app-host.example.com
# Admin API version to call
SHOPIFY_API_VERSION=2024-10

# ---- Database ----
DATABASE_URL=postgres://user:password@localhost:5432/decision_replay

# ---- Security ----
# 32-byte key (hex or base64) used to encrypt access tokens at rest
TOKEN_ENCRYPTION_KEY=please_generate_a_strong_32_byte_key
# Secret used to sign short-lived state cookies during OAuth
SESSION_SECRET=please_generate_a_random_string

# ---- Runtime ----
PORT=3000
NODE_ENV=development
